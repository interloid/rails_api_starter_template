# ---- Injected by the platform in production (NOT auto-loaded) ----
# Decrypts config/credentials/production.yml.enc
RAILS_MASTER_KEY=

# Infra / per-deploy config (belongs in ENV, not credentials)
RAILS_ENV=production
DATABASE_URL=postgres://user:pass@host:5432/rails_starter_template_production
RAILS_MAX_THREADS=5
PORT=3000
WEB_CONCURRENCY=2

# ---- Optional local overrides (anyway_config reads APP_* automatically) ----
# APP_HOST=localhost
# APP_PORT=3000
# APP_LOG_LEVEL=debug

# ---- Logging / Observability ----
SERVICE_NAME=rails_starter_template
# Rails log verbosity in production (debug|info|warn|error). Defaults to info.
RAILS_LOG_LEVEL=info

# New Relic — agent stays fully inert unless a license key is set.
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=rails_starter_template
# Local testing only: set to true to send data from development to New Relic.
# Requires NEW_RELIC_LICENSE_KEY to also be set. Never needed in production.
NEW_RELIC_MONITOR_MODE=false
# For LOCAL New Relic testing, copy your key into .env.development.local
# (gitignored, auto-loaded in dev). Do NOT put real keys in this example file.

# ---- Health checks ----
# Production only: set to expose full /health "info" (commit, versions) via the
# X-Health-Token request header. Leave blank to keep prod /health minimal.
HEALTH_CHECK_TOKEN=
# Optional app version shown in /health info:
APP_VERSION=
# GIT_SHA is injected by the Docker build (Section 14) — do NOT set manually.

# ---- Security ----
# CORS: comma-separated allowed origins. Empty in production = no cross-origin allowed.
CORS_ORIGINS=
# Global per-IP rate limit (defense-in-depth). Defaults match ApplicationController.
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WITHIN_SECONDS=60
# REQUIRED in production: comma-separated allowed hosts (e.g. api.example.com).
# The app refuses to boot without this unless ALLOW_ALL_HOSTS=true.
ALLOWED_HOSTS=
# Explicit opt-out when host validation is handled upstream (LB/gateway):
ALLOW_ALL_HOSTS=false
# Redirect HTTP->HTTPS in production. Set false only for local container testing or
# when TLS is terminated upstream.
FORCE_SSL=true
# Opt-in access-token revocation. Access JWTs are stateless and valid for their full
# 15-min TTL by default. Set true to check a Rails.cache denylist on every request
# (adds one cache read per authenticated request; enables immediate logout/compromise
# revocation).
JWT_DENYLIST_ENABLED=false
# JWT issuer/audience claims (default to SERVICE_NAME). Set explicitly when tokens
# cross service boundaries.
JWT_ISSUER=
JWT_AUDIENCE=
# Role automatically assigned to newly registered users:
DEFAULT_USER_ROLE=member
# Require a confirmed email before login is allowed:
REQUIRE_EMAIL_CONFIRMATION=false

# ---- Mail (SMTP configured in Section 12) ----
MAILER_FROM=no-reply@example.com
FRONTEND_URL=http://localhost:3000

# ---- SMTP (credentials hold user_name/password; these are host settings only) ----
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
# Public host used to build absolute URLs in production emails:
APP_HOST=api.example.com

# ---- Background jobs ----
# Run Solid Queue inside the Puma process (single-server). Unset to use a separate bin/jobs worker.
SOLID_QUEUE_IN_PUMA=true

# ---- Shutdown ----
# Path to a sentinel file; when present, /health/ready returns 503 so the load balancer
# drains this instance before SIGTERM. A container preStop hook creates it (Section 14).
SHUTDOWN_SENTINEL_PATH=tmp/shutdown
