# ---- Injected by the platform in production (NOT auto-loaded) ----
# Decrypts config/credentials/production.yml.enc
RAILS_MASTER_KEY=

# Infra / per-deploy config (belongs in ENV, not credentials)
RAILS_ENV=production
DATABASE_URL=postgres://user:pass@host:5432/backend_starter_production
RAILS_MAX_THREADS=5
PORT=3000
WEB_CONCURRENCY=2

# ---- Optional local overrides (anyway_config reads APP_* automatically) ----
# APP_HOST=localhost
# APP_PORT=3000
# APP_LOG_LEVEL=debug

# ---- Logging / Observability ----
SERVICE_NAME=backend_starter

# New Relic — agent stays fully inert unless a license key is set.
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=rails_starter_template
# Local testing only: set to true to send data from development to New Relic.
# Requires NEW_RELIC_LICENSE_KEY to also be set. Never needed in production.
NEW_RELIC_MONITOR_MODE=false
# For LOCAL New Relic testing, copy your key into .env.development.local
# (gitignored, auto-loaded in dev). Do NOT put real keys in this example file.
