RAILS_ENV=production
# The container runs RAILS_ENV=production, which decrypts
# config/credentials/production.yml.enc — so this must be the contents of
# config/credentials/production.key, NOT config/master.key.
RAILS_MASTER_KEY=
DATABASE_URL=postgres://postgres:postgres@db:5432/rails_starter_template_development
SERVICE_NAME=rails_starter_template
SOLID_QUEUE_IN_PUMA=true
RUN_DB_PREPARE=true
PORT=3000
ALLOWED_HOSTS=localhost
CORS_ORIGINS=http://localhost:5173
FORCE_SSL=false
